APP_URL=http://localhost:8000
WEB_URL=http://localhost:5173
PORT=8000
DATABASE_URL=postgresql://dgchat:dgchat@localhost:5432/dgchat
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=dg-chat
S3_ACCESS_KEY=dgchat
S3_SECRET_KEY=change-me
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minio-root
MINIO_ROOT_PASSWORD=replace-with-a-strong-root-password
MINIO_APP_POLICY_NAME=dg-chat-local-app
APP_SECRET=replace-with-at-least-32-random-bytes
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=replace-with-an-exact-32-byte-base64-key
# For rolling rotation, replace ENCRYPTION_KEY with both variables below:
# ENCRYPTION_KEYRING={"2026-01":"base64-32-byte-key","2026-07":"base64-32-byte-key"}
# ENCRYPTION_PRIMARY_KEY_ID=2026-07
SETUP_TOKEN=replace-with-one-time-bootstrap-token
DEFAULT_APPROVAL_CREDIT_USD=5.00
UPLOAD_MAX_BYTES=26214400
UPLOAD_MAX_CONCURRENT=4
UPLOAD_MAX_CONCURRENT_PER_USER=2
WORKER_JOB_LEASE_SECONDS=120
AUTH_RATE_LIMIT=10
AUTH_CLIENT_RATE_LIMIT=100
RATE_LIMIT_WINDOW_SECONDS=60
PROVIDER_ADMIN_RATE_LIMIT=30
# Optional slow-stream guard; configure both values to enable it.
# PROVIDER_SLOW_STREAM_WINDOW_MS=5000
# PROVIDER_MIN_VISIBLE_UNITS_PER_SECOND=2
TRUST_PROXY_HEADERS=false
REPLAY_MAX_REQUESTS_PER_USER=256
REPLAY_MAX_BYTES_PER_USER=67108864
REPLAY_MAX_EVENTS_PER_USER=20000
SMTP_URL=
SMTP_FROM=DG Chat <no-reply@example.com>
REQUIRE_EMAIL_VERIFICATION=false
OIDC_DISCOVERY_URL=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
