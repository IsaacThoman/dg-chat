APP_URL=http://localhost:8000
WEB_URL=http://localhost:5173
PORT=8000
# Host-run development values. docker-compose.dev.yml replaces these with container service DNS;
# docker-compose.managed.yml instead requires explicit externally reachable values.
DATABASE_URL=postgresql://dgchat:dgchat@localhost:5432/dgchat
REDIS_URL=redis://localhost:6379
S3_ENDPOINT=http://localhost:9000
# Required for HTTP endpoints and accepted only for loopback, private-network, or container hosts.
S3_ALLOW_INSECURE=true
S3_REGION=us-east-1
S3_BUCKET=dg-chat
S3_ACCESS_KEY=dgchat
S3_SECRET_KEY=change-me
S3_FORCE_PATH_STYLE=true
MINIO_ROOT_USER=minio-root
MINIO_ROOT_PASSWORD=replace-with-a-strong-root-password
MINIO_APP_POLICY_NAME=dg-chat-local-app
APP_SECRET=replace-with-at-least-32-random-bytes
# Optional independent key for five-minute OpenAI image asset URLs; APP_SECRET is used otherwise.
# Generate with: openssl rand -base64 32
# Optional: set IMAGE_URL_SIGNING_SECRET to an independently generated 32-byte value.
# Generate with: openssl rand -base64 32
ENCRYPTION_KEY=replace-with-an-exact-32-byte-base64-key
# For rolling rotation, replace ENCRYPTION_KEY with both variables below:
# ENCRYPTION_KEYRING={"2026-01":"base64-32-byte-key","2026-07":"base64-32-byte-key"}
# ENCRYPTION_PRIMARY_KEY_ID=2026-07
# Independent HMAC key used to authenticate portable backup manifests. Never rotate it away while
# retained .dgbackup files still depend on it. Generate with: openssl rand -base64 32
BACKUP_SIGNING_KEY=replace-with-an-exact-32-byte-base64-key
BACKUP_SIGNING_KEY_ID=installation-v1
# Disabled by default. When enabled, this independent rotating keyring encrypts the separately
# authorized provider-secret recovery sidecar. Never reuse provider-encryption or signing keys.
ENABLE_PRIVILEGED_SECRET_BACKUPS=false
# BACKUP_SECRET_KEYRING={"recovery-2026-01":"independent-base64-32-byte-key"}
# BACKUP_SECRET_PRIMARY_KEY_ID=recovery-2026-01
# Restore replaces installation data and invalidates sessions, so it is an explicit operator opt-in.
ALLOW_IN_APP_RESTORE=false
BACKUP_MAX_UPLOAD_BYTES=1073741824
# Docker Compose /tmp quota for backup spooling as well as ordinary temporary files.
BACKUP_TEMP_STORAGE_SIZE=2g
SETUP_TOKEN=replace-with-one-time-bootstrap-token
DEFAULT_APPROVAL_CREDIT_USD=5.00
# Temporary chats are never exported or organized and are permanently purged after this window.
TEMPORARY_CHAT_RETENTION_DAYS=30
# The worker deletes at most one bounded batch per pass; full batches continue on its normal poll.
TEMPORARY_CHAT_PURGE_INTERVAL_SECONDS=300
TEMPORARY_CHAT_PURGE_BATCH_SIZE=100
UPLOAD_MAX_BYTES=26214400
UPLOAD_MAX_CONCURRENT=4
UPLOAD_MAX_CONCURRENT_PER_USER=2
AUDIO_MAX_CONCURRENT=4
AUDIO_MAX_CONCURRENT_PER_USER=2
AUDIO_CONCURRENCY_LEASE_SECONDS=120
IMAGE_MAX_CONCURRENT=2
IMAGE_MAX_CONCURRENT_PER_USER=1
# Reconcile generated-image objects left behind by a hard API-process crash.
GENERATED_OBJECT_CLEANUP_GRACE_SECONDS=600
GENERATED_OBJECT_CLEANUP_SWEEP_MS=60000
ATTACHMENT_CONTEXT_MAX_RAW_BYTES=16777216
# Maximum combined knowledge text injected into one generation and retrieval chunk count.
KNOWLEDGE_CONTEXT_MAX_CHARACTERS=32000
KNOWLEDGE_RETRIEVAL_TOP_K=12
# Configure the same OpenAI-compatible embedding endpoint for both the API query path and worker
# document path. Docker Compose passes these values to both services so their versioned vectors
# cannot silently diverge. Use a credential-free HTTPS base URL outside the test harness.
KNOWLEDGE_EMBEDDING_BASE_URL=
KNOWLEDGE_EMBEDDING_API_KEY=
KNOWLEDGE_EMBEDDING_MODEL=
KNOWLEDGE_EMBEDDING_UPSTREAM_MODEL=
KNOWLEDGE_EMBEDDING_VERSION=
KNOWLEDGE_EMBEDDING_BATCH_SIZE=64
KNOWLEDGE_EMBEDDING_QUERY_TIMEOUT_MS=10000
# USD-micro pricing used by both ingestion and query accounting. Zero is valid for local models.
KNOWLEDGE_EMBEDDING_INPUT_MICROS_PER_MILLION=0
KNOWLEDGE_EMBEDDING_FIXED_CALL_MICROS=0
# Compose includes a pinned, network-isolated SearXNG service. Tools remain unavailable until an
# admin allowlists `searxng` and explicitly permits private-network access for the search tool.
SEARXNG_URL=http://searxng:8080
SEARXNG_ALLOW_PRIVATE_NETWORK=true
# Generate independently with: openssl rand -hex 32
SEARXNG_SECRET=replace-with-an-independent-random-secret
SEARXNG_TIMEOUT_MS=8000
SEARXNG_MAX_RESPONSE_BYTES=2000000
WORKER_JOB_LEASE_SECONDS=120
WORKER_JOB_DEADLINE_MARGIN_MS=5000
# Bounded exponential retry for startup and transient runtime database outages.
WORKER_DATABASE_RETRY_INITIAL_MS=250
WORKER_DATABASE_RETRY_MAX_MS=10000
# Randomly subtract up to this fraction from each delay to desynchronize worker replicas.
WORKER_DATABASE_RETRY_JITTER_RATIO=0.2
# Hard ceiling for every worker SQL statement, including lock waits. Shutdown settlement gets one
# absolute window (including retry and pool close) and must stay below Compose stop_grace_period.
WORKER_DATABASE_OPERATION_TIMEOUT_MS=5000
WORKER_SHUTDOWN_SETTLEMENT_TIMEOUT_MS=10000
# Durable boot-scoped liveness. Heartbeat detects a dead process/dependency loop; progress detects a
# live but wedged poller or job. Keep stale heartbeat at least twice the heartbeat interval.
WORKER_HEARTBEAT_INTERVAL_MS=5000
WORKER_HEARTBEAT_STALE_MS=20000
WORKER_PROGRESS_STALE_MS=180000
WORKER_HEALTH_TIMEOUT_MS=4000
WORKER_HEALTH_CLOCK_TOLERANCE_MS=5000
WORKER_INSTANCE_RETENTION_HOURS=168
# Set a distinct path per bare-metal worker when several processes share one /tmp namespace.
WORKER_INSTANCE_FILE=/tmp/dg-chat-worker-instance
DOCUMENT_CHUNK_SIZE_CHARS=4000
DOCUMENT_CHUNK_OVERLAP_CHARS=400
DOCUMENT_EXTRACTOR_VERSION=builtin-document-v1
DOCUMENT_CHUNKER_VERSION=character-window-v1
DOCUMENT_EXTRACTION_MAX_RAW_BYTES=20971520
DOCUMENT_EXTRACTION_TIMEOUT_MS=30000
DOCUMENT_EXTRACTION_MAX_OUTPUT_CHARACTERS=2000000
DOCUMENT_EXTRACTION_MAX_PDF_PAGES=1000
DOCUMENT_EXTRACTION_MAX_ZIP_ENTRIES=2000
DOCUMENT_EXTRACTION_MAX_ZIP_ENTRY_BYTES=26214400
DOCUMENT_EXTRACTION_MAX_ZIP_EXPANDED_BYTES=104857600
DOCUMENT_EXTRACTION_MAX_ZIP_RATIO=200
AUTH_RATE_LIMIT=10
AUTH_CLIENT_RATE_LIMIT=100
RATE_LIMIT_WINDOW_SECONDS=60
PROVIDER_ADMIN_RATE_LIMIT=30
PUBLIC_SHARE_RATE_LIMIT=120
PUBLIC_SHARE_CLIENT_RATE_LIMIT=240
SHARE_MUTATION_RATE_LIMIT=20
CONVERSATION_SEARCH_RATE_LIMIT=30
CONVERSATION_SEARCH_MAX_CONCURRENT=4
CONVERSATION_SEARCH_MAX_CONCURRENT_PER_USER=1
# Must be greater than the 5-second database statement deadline; crash recovery is bounded by it.
CONVERSATION_SEARCH_CONCURRENCY_LEASE_SECONDS=15
TOKEN_DEFAULT_BURST_LIMIT=20
# Optional slow-stream guard; configure both values to enable it.
# PROVIDER_SLOW_STREAM_WINDOW_MS=5000
# PROVIDER_MIN_VISIBLE_UNITS_PER_SECOND=2
TRUST_PROXY_HEADERS=false
REPLAY_MAX_REQUESTS_PER_USER=256
REPLAY_MAX_BYTES_PER_USER=67108864
REPLAY_MAX_EVENTS_PER_USER=20000
SMTP_URL=
SMTP_FROM=DG Chat <no-reply@example.com>
REQUIRE_EMAIL_VERIFICATION=false
OIDC_DISCOVERY_URL=
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_PROVIDER_ID=organization
OIDC_ALLOWED_ALGORITHMS=RS256
OIDC_ALLOW_INSECURE_HTTP=false
OIDC_ALLOW_PRIVATE_NETWORK=false
OIDC_ALLOWED_ENDPOINT_ORIGINS=
# Hard per-dependency bounds for /ready probes (milliseconds).
READINESS_TIMEOUT_MS=2000
# POSTGRES_READINESS_TIMEOUT_MS=2000
# REDIS_READINESS_TIMEOUT_MS=2000
# S3_READINESS_TIMEOUT_MS=2000

# Internal Prometheus exporters. Compose binds these listeners only to the private backend network;
# neither port is published by app/worker and public nginx continues to return 404 for /metrics.
METRICS_ENABLED=true
API_METRICS_PORT=9090
WORKER_METRICS_PORT=9091
# Start the optional local scraper/UI with: docker compose --profile observability up -d prometheus
PROMETHEUS_BIND_ADDRESS=127.0.0.1
PROMETHEUS_HOST_PORT=9090
PROMETHEUS_RETENTION=15d

# Privacy-bounded manual OpenTelemetry spans use W3C trace context and batched OTLP export. Native
# Deno auto-instrumentation must remain disabled because it retains raw URLs and query strings.
# Keep exporter authentication headers in a protected deployment secret; DG Chat never logs them.
DG_CHAT_OTEL_ENABLED=false
OTEL_DENO=false
OTEL_API_SERVICE_NAME=dg-chat-api
OTEL_WORKER_SERVICE_NAME=dg-chat-worker
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# OTEL_EXPORTER_OTLP_HEADERS=authorization=Bearer%20replace-me
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=0.1
