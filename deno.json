{
  "workspace": [
    "./apps/api",
    "./apps/mock-oidc",
    "./apps/worker",
    "./apps/web",
    "./packages/contracts",
    "./packages/database"
  ],
  "nodeModulesDir": "manual",
  "tasks": {
    "dev": "deno task --filter @dg-chat/api dev",
    "dev:web": "deno task --filter @dg-chat/web dev",
    "dev:worker": "deno task --filter @dg-chat/worker dev",
    "check": "deno fmt --check && deno lint && deno check apps/api/src/main.ts apps/worker/src/main.ts apps/web/src/main.tsx packages/contracts/mod.ts packages/database/mod.ts",
    "test": "deno test --unstable-worker-options apps/api apps/worker packages/contracts packages/database --allow-env --allow-net --allow-read --allow-write",
    "test:web": "deno task --filter @dg-chat/web test",
    "build": "deno task --filter @dg-chat/web build",
    "db:generate": "deno task --filter @dg-chat/database generate",
    "db:migrate": "deno task --filter @dg-chat/database migrate"
  },
  "fmt": {
    "lineWidth": 100,
    "semiColons": true,
    "singleQuote": false
  },
  "lint": {
    "rules": {
      "tags": ["recommended"]
    }
  }
}
